{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "noEmitOnError": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests/**/*", "demo/**/*"]
}
